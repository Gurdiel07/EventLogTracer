<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EventLogTracer.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="EventLogTracer.App.Views.AlertsView"
             x:Name="AlertsViewRoot"
             x:DataType="vm:AlertsViewModel">

    <!-- 2-column layout: Rules list | Edit panel -->
    <Grid ColumnDefinitions="*,400">

        <!-- ══════════════════════════════════════════════════════════════════
             COLUMN 0 — Rules list
             ══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="0"
              RowDefinitions="Auto,*"
              Margin="24,24,12,24">

            <!-- Header row -->
            <Grid ColumnDefinitions="*,Auto" Grid.Row="0" Margin="0,0,0,16">
                <StackPanel Spacing="4">
                    <TextBlock Text="Alerts"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#F0F4FF"/>
                    <TextBlock Text="Configure rules to get notified when specific events occur"
                               FontSize="13"
                               Foreground="#7B8CA8"/>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="10"
                            VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True"
                                 IsVisible="{Binding IsLoading}"
                                 Height="2"
                                 Width="70"
                                 Background="Transparent"
                                 VerticalAlignment="Center"/>
                    <Button Content="+ New Rule"
                            Command="{Binding NewRuleCommand}"
                            Background="#3b82f6"
                            Foreground="White"
                            Padding="14,8"
                            CornerRadius="4"
                            VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Rules area -->
            <Grid Grid.Row="1">
                <!-- Empty state -->
                <Border IsVisible="{Binding NoRules}"
                        Background="#0F1520"
                        CornerRadius="12"
                        Padding="32">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="8">
                        <TextBlock Text="🔔"
                                   FontSize="36"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="No alert rules configured"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#E8E9ED"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Create one to get notified when specific events occur."
                                   FontSize="13"
                                   Foreground="#4A5670"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Rules list (x:CompileBindings=False for DataTemplate cross-binding) -->
                <ScrollViewer IsVisible="{Binding HasRules}">
                    <ItemsControl x:CompileBindings="False"
                                  ItemsSource="{Binding AlertRules}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0F1520"
                                        CornerRadius="8"
                                        Padding="14"
                                        Margin="0,0,0,8"
                                        BorderBrush="#1A2744"
                                        BorderThickness="3,1,1,1">
                                    <Grid RowDefinitions="Auto,Auto,Auto">

                                        <!-- Row 0: Name + badges + actions -->
                                        <Grid ColumnDefinitions="*,Auto" Grid.Row="0">
                                            <StackPanel Orientation="Horizontal" Spacing="8">

                                                <!-- Rule name -->
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="#FFFFFF"
                                                           VerticalAlignment="Center"/>

                                                <!-- Notification type badge -->
                                                <Border Background="{Binding NotificationType,
                                                                    Converter={StaticResource NotificationTypeToColorConverter}}"
                                                        CornerRadius="4"
                                                        Padding="6,2">
                                                    <TextBlock Text="{Binding NotificationType}"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"/>
                                                </Border>

                                                <!-- Enabled/Disabled badge -->
                                                <Border Background="#107C10" CornerRadius="4" Padding="6,2"
                                                        IsVisible="{Binding IsEnabled}">
                                                    <TextBlock Text="ON" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                                </Border>
                                                <Border Background="#605E5C" CornerRadius="4" Padding="6,2"
                                                        IsVisible="{Binding !IsEnabled}">
                                                    <TextBlock Text="OFF" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                                </Border>

                                            </StackPanel>

                                            <!-- Action buttons -->
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                                <!-- Toggle: show "Disable" when enabled, "Enable" when disabled -->
                                                <Button IsVisible="{Binding IsEnabled}"
                                                        Content="Disable"
                                                        Command="{Binding DataContext.ToggleRuleCommand, ElementName=AlertsViewRoot}"
                                                        CommandParameter="{Binding}"
                                                        Padding="8,4"
                                                        FontSize="12"
                                                        Background="#131A28"
                                                        Foreground="#E8E9ED"
                                                        CornerRadius="4"/>
                                                <Button IsVisible="{Binding !IsEnabled}"
                                                        Content="Enable"
                                                        Command="{Binding DataContext.ToggleRuleCommand, ElementName=AlertsViewRoot}"
                                                        CommandParameter="{Binding}"
                                                        Padding="8,4"
                                                        FontSize="12"
                                                        Background="#1E3A1E"
                                                        Foreground="#6FCF6F"
                                                        CornerRadius="4"/>
                                                <Button Command="{Binding DataContext.EditRuleCommand, ElementName=AlertsViewRoot}"
                                                        CommandParameter="{Binding}"
                                                        Padding="8,4"
                                                        FontSize="12"
                                                        Background="#131A28"
                                                        Foreground="#E8E9ED"
                                                        CornerRadius="4"
                                                        Content="Edit"/>
                                                <Button Command="{Binding DataContext.DeleteRuleCommand, ElementName=AlertsViewRoot}"
                                                        CommandParameter="{Binding}"
                                                        Padding="8,4"
                                                        FontSize="12"
                                                        Background="#4A1A1A"
                                                        Foreground="#FF6B6B"
                                                        CornerRadius="4"
                                                        Content="Delete"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Row 1: Notification target -->
                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding NotificationTarget}"
                                                   FontSize="12"
                                                   Foreground="#8899B4"
                                                   Margin="0,4,0,0"
                                                   TextTrimming="CharacterEllipsis"
                                                   IsVisible="{Binding NotificationTarget, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                                        <!-- Row 2: Filter description -->
                                        <TextBlock Grid.Row="2"
                                                   Text="{Binding Filter, Converter={StaticResource FilterDescriptionConverter}}"
                                                   FontSize="11"
                                                   Foreground="#4A5670"
                                                   Margin="0,4,0,0"
                                                   TextTrimming="CharacterEllipsis"/>

                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════
             COLUMN 1 — Edit panel
             ══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="1"
                Background="#0F1520"
                BorderBrush="#1E3A5F"
                BorderThickness="1,0,0,0"
                IsVisible="{Binding IsEditing}">
            <ScrollViewer Padding="24">
                <StackPanel Spacing="16">

                    <!-- Panel title -->
                    <TextBlock Text="{Binding EditPanelTitle}"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#F0F4FF"/>

                    <!-- Name -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Rule Name" FontSize="12" Foreground="#7B8CA8"/>
                        <TextBox Text="{Binding EditName}"
                                 Watermark="e.g. Critical security events"
                                 Background="#131A28"
                                 Foreground="#FFFFFF"
                                 BorderBrush="#1A2744"
                                 Padding="10,8"
                                 CornerRadius="4"/>
                    </StackPanel>

                    <!-- Enabled toggle -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Status" FontSize="12" Foreground="#7B8CA8"/>
                        <ToggleSwitch IsChecked="{Binding EditIsEnabled}"
                                      OnContent="Enabled"
                                      OffContent="Disabled"
                                      Foreground="#E8E9ED"/>
                    </StackPanel>

                    <!-- Notification Type -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Notification Type" FontSize="12" Foreground="#7B8CA8"/>
                        <ComboBox x:CompileBindings="False"
                                  ItemsSource="{Binding NotificationTypeOptions}"
                                  SelectedItem="{Binding EditNotificationType}"
                                  Background="#131A28"
                                  Foreground="#E8E9ED"
                                  BorderBrush="#1A2744"
                                  HorizontalAlignment="Stretch"
                                  Padding="10,8"/>
                    </StackPanel>

                    <!-- Notification Target -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Notification Target" FontSize="12" Foreground="#7B8CA8"/>
                        <TextBox Text="{Binding EditNotificationTarget}"
                                 Watermark="{Binding EditNotificationTargetWatermark}"
                                 Background="#131A28"
                                 Foreground="#FFFFFF"
                                 BorderBrush="#1A2744"
                                 Padding="10,8"
                                 CornerRadius="4"/>
                    </StackPanel>

                    <!-- Separator -->
                    <Border Height="1" Background="#1E3A5F" Margin="0,8"/>
                    <TextBlock Text="FILTER CRITERIA"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#4A5670"
                               LetterSpacing="1.5"/>

                    <!-- Event Levels -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Event Levels" FontSize="12" Foreground="#7B8CA8"/>
                        <TextBox Text="{Binding EditFilterLevels}"
                                 Watermark="e.g. Error, Critical"
                                 Background="#131A28"
                                 Foreground="#FFFFFF"
                                 BorderBrush="#1A2744"
                                 Padding="10,8"
                                 CornerRadius="4"/>
                        <TextBlock Text="Comma-separated: Verbose, Information, Warning, Error, Critical"
                                   FontSize="10"
                                   Foreground="#4A5670"/>
                    </StackPanel>

                    <!-- Sources -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Sources" FontSize="12" Foreground="#7B8CA8"/>
                        <TextBox Text="{Binding EditFilterSources}"
                                 Watermark="e.g. DCOM, SecurityAuditing"
                                 Background="#131A28"
                                 Foreground="#FFFFFF"
                                 BorderBrush="#1A2744"
                                 Padding="10,8"
                                 CornerRadius="4"/>
                    </StackPanel>

                    <!-- Log Names -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Log Names" FontSize="12" Foreground="#7B8CA8"/>
                        <TextBox Text="{Binding EditFilterLogNames}"
                                 Watermark="e.g. Security, System"
                                 Background="#131A28"
                                 Foreground="#FFFFFF"
                                 BorderBrush="#1A2744"
                                 Padding="10,8"
                                 CornerRadius="4"/>
                    </StackPanel>

                    <!-- Event IDs -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Event IDs" FontSize="12" Foreground="#7B8CA8"/>
                        <TextBox Text="{Binding EditFilterEventIds}"
                                 Watermark="e.g. 4625, 4648"
                                 Background="#131A28"
                                 Foreground="#FFFFFF"
                                 BorderBrush="#1A2744"
                                 Padding="10,8"
                                 CornerRadius="4"/>
                    </StackPanel>

                    <!-- Search Text -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Message Contains" FontSize="12" Foreground="#7B8CA8"/>
                        <TextBox Text="{Binding EditFilterSearchText}"
                                 Watermark="Text to match in the event message"
                                 Background="#131A28"
                                 Foreground="#FFFFFF"
                                 BorderBrush="#1A2744"
                                 Padding="10,8"
                                 CornerRadius="4"/>
                    </StackPanel>

                    <!-- Action buttons -->
                    <Border Height="1" Background="#1E3A5F" Margin="0,4"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button Content="Cancel"
                                Command="{Binding CancelEditCommand}"
                                Padding="14,9"
                                CornerRadius="4"
                                Background="#131A28"
                                Foreground="#E8E9ED"/>
                        <Button Content="Save Rule"
                                Command="{Binding SaveRuleCommand}"
                                Padding="14,9"
                                CornerRadius="4"
                                Background="#3b82f6"
                                Foreground="White"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>

    </Grid>
</UserControl>
