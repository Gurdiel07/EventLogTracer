<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EventLogTracer.App.ViewModels"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="EventLogTracer.App.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" Spacing="20">

            <!-- ══════════════════════════════════════════════════════
                 Row 0 — Header + Refresh
                 ══════════════════════════════════════════════════════ -->
            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Dashboard"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#FFFFFF"/>
                    <TextBlock Text="Event activity overview — last 24 hours"
                               FontSize="12"
                               Foreground="#6B6F82"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="10"
                            VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True"
                                 IsVisible="{Binding IsLoading}"
                                 Height="2"
                                 Width="80"
                                 Background="Transparent"
                                 VerticalAlignment="Center"/>
                    <Button Content="⟳ Refresh"
                            Command="{Binding RefreshCommand}"
                            Padding="14,8"
                            CornerRadius="4"/>
                </StackPanel>

            </Grid>

            <!-- ══════════════════════════════════════════════════════
                 Welcome / Empty state
                 ══════════════════════════════════════════════════════ -->
            <Border Background="#181C26"
                    CornerRadius="12"
                    Padding="40"
                    BorderBrush="#2E3348"
                    BorderThickness="1"
                    IsVisible="{Binding NoData}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="10">
                    <TextBlock Text="⚡"
                               FontSize="56"
                               HorizontalAlignment="Center"
                               Foreground="#3b82f6"/>
                    <TextBlock Text="Welcome to Event Log Tracer"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#FFFFFF"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Click 'Start Monitoring' to begin collecting events"
                               FontSize="14"
                               Foreground="#A0A4B8"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════════════════════
                 Row 1 — Summary cards (5 cards)
                 ══════════════════════════════════════════════════════ -->
            <WrapPanel Orientation="Horizontal"
                       IsVisible="{Binding HasData}">

                <!-- Critical -->
                <Border Background="#181C26" CornerRadius="12" Padding="20"
                        Margin="0,0,14,10" Width="180"
                        BorderBrush="#3D1520" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Critical"
                                   Foreground="#E81123"
                                   FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding CriticalCount}"
                                   FontSize="36" FontWeight="Bold"
                                   Foreground="#FFFFFF" Margin="0,8,0,0"/>
                        <TextBlock Text="events"
                                   Foreground="#6B6F82" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Error -->
                <Border Background="#181C26" CornerRadius="12" Padding="20"
                        Margin="0,0,14,10" Width="180"
                        BorderBrush="#2D1520" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Error"
                                   Foreground="#D13438"
                                   FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding ErrorCount}"
                                   FontSize="36" FontWeight="Bold"
                                   Foreground="#FFFFFF" Margin="0,8,0,0"/>
                        <TextBlock Text="events"
                                   Foreground="#6B6F82" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Warning -->
                <Border Background="#181C26" CornerRadius="12" Padding="20"
                        Margin="0,0,14,10" Width="180"
                        BorderBrush="#2D2818" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Warning"
                                   Foreground="#FF8C00"
                                   FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding WarningCount}"
                                   FontSize="36" FontWeight="Bold"
                                   Foreground="#FFFFFF" Margin="0,8,0,0"/>
                        <TextBlock Text="events"
                                   Foreground="#6B6F82" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Information -->
                <Border Background="#181C26" CornerRadius="12" Padding="20"
                        Margin="0,0,14,10" Width="180"
                        BorderBrush="#162038" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Information"
                                   Foreground="#0078D4"
                                   FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding InformationCount}"
                                   FontSize="36" FontWeight="Bold"
                                   Foreground="#FFFFFF" Margin="0,8,0,0"/>
                        <TextBlock Text="events"
                                   Foreground="#6B6F82" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Total -->
                <Border Background="#181C26" CornerRadius="12" Padding="20"
                        Margin="0,0,0,10" Width="180"
                        BorderBrush="#3A3F58" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Total"
                                   Foreground="#E8E9ED"
                                   FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TotalCount}"
                                   FontSize="36" FontWeight="Bold"
                                   Foreground="#FFFFFF" Margin="0,8,0,0"/>
                        <TextBlock Text="events (24h)"
                                   Foreground="#6B6F82" FontSize="12"/>
                    </StackPanel>
                </Border>

            </WrapPanel>

            <!-- ══════════════════════════════════════════════════════
                 Row 2 — Charts: Pie (left) + Timeline (right)
                 ══════════════════════════════════════════════════════ -->
            <Grid ColumnDefinitions="*,*"
                  IsVisible="{Binding HasData}">

                <!-- Pie chart: Level Distribution -->
                <Border Grid.Column="0"
                        Background="#181C26"
                        CornerRadius="12"
                        Padding="16"
                        Margin="0,0,10,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Event Level Distribution"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="#E8E9ED"/>

                        <lvc:PieChart x:CompileBindings="False"
                                      Series="{Binding LevelPieSeries}"
                                      LegendPosition="Bottom"
                                      LegendTextPaint="{Binding LegendTextPaint}"
                                      Height="270"
                                      Background="Transparent"/>
                    </StackPanel>
                </Border>

                <!-- Line chart: Events Over Time -->
                <Border Grid.Column="1"
                        Background="#181C26"
                        CornerRadius="12"
                        Padding="16"
                        Margin="10,0,0,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Events Over Time (24h)"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="#E8E9ED"/>

                        <lvc:CartesianChart x:CompileBindings="False"
                                            Series="{Binding EventsTimelineSeries}"
                                            XAxes="{Binding TimelineXAxes}"
                                            YAxes="{Binding TimelineYAxes}"
                                            Height="270"
                                            Background="Transparent"
                                            TooltipPosition="Top"/>
                    </StackPanel>
                </Border>

            </Grid>

            <!-- ══════════════════════════════════════════════════════
                 Row 3 — Bar chart: Top 10 Sources (full width)
                 ══════════════════════════════════════════════════════ -->
            <Border Background="#181C26"
                    CornerRadius="12"
                    Padding="16"
                    IsVisible="{Binding HasData}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Top 10 Event Sources"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#E8E9ED"/>

                    <lvc:CartesianChart x:CompileBindings="False"
                                        Series="{Binding TopSourcesBarSeries}"
                                        XAxes="{Binding SourcesXAxes}"
                                        YAxes="{Binding SourcesYAxes}"
                                        Height="340"
                                        Background="Transparent"
                                        TooltipPosition="Top"/>
                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════════════════════
                 Row 4 — Anomaly Detection
                 ══════════════════════════════════════════════════════ -->
            <Border Background="#181C26"
                    CornerRadius="12"
                    Padding="16"
                    BorderBrush="#2E3348"
                    BorderThickness="1"
                    IsVisible="{Binding HasData}">
                <StackPanel Spacing="12">

                    <!-- Header row -->
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock Text="Anomaly Detection"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#FFFFFF"/>
                            <Border Background="#D83B01"
                                    CornerRadius="10"
                                    Padding="9,3"
                                    VerticalAlignment="Center"
                                    IsVisible="{Binding HasAnomalies}">
                                <TextBlock Text="{Binding AnomalyCount, StringFormat='{}{0} detected'}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="10"
                                    VerticalAlignment="Center">
                            <ProgressBar IsIndeterminate="True"
                                         IsVisible="{Binding IsDetectingAnomalies}"
                                         Height="2"
                                         Width="60"
                                         Background="Transparent"
                                         VerticalAlignment="Center"/>
                            <Button Content="Run Detection"
                                    Command="{Binding DetectAnomaliesCommand}"
                                    IsEnabled="{Binding !IsDetectingAnomalies}"
                                    Padding="12,7"
                                    CornerRadius="4"/>
                        </StackPanel>
                    </Grid>

                    <!-- Empty state -->
                    <StackPanel Orientation="Horizontal"
                                Spacing="10"
                                IsVisible="{Binding NoAnomalies}">
                        <TextBlock Text="✓"
                                   FontSize="18"
                                   Foreground="#00C851"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="No anomalies detected in the last 24 hours."
                                   FontSize="13"
                                   Foreground="#A0A4B8"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Anomaly cards -->
                    <ItemsControl x:CompileBindings="False"
                                  ItemsSource="{Binding AnomalyResults}"
                                  IsVisible="{Binding HasAnomalies}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#101318"
                                        CornerRadius="8"
                                        Margin="0,0,0,8"
                                        BorderBrush="#2E3348"
                                        BorderThickness="1">
                                    <Grid ColumnDefinitions="5,*">

                                        <!-- Severity accent bar (left edge) -->
                                        <Border Grid.Column="0"
                                                CornerRadius="8,0,0,8"
                                                Background="{Binding Severity,
                                                             Converter={StaticResource AnomalySeverityToColorConverter}}"/>

                                        <!-- Card content -->
                                        <StackPanel Grid.Column="1" Margin="14,10" Spacing="5">

                                            <!-- Title + severity badge -->
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="#FFFFFF"
                                                           TextWrapping="Wrap"/>
                                                <Border Grid.Column="1"
                                                        CornerRadius="4"
                                                        Padding="7,2"
                                                        Margin="10,0,0,0"
                                                        VerticalAlignment="Top"
                                                        Background="{Binding Severity,
                                                                     Converter={StaticResource AnomalySeverityToColorConverter}}">
                                                    <TextBlock Text="{Binding Severity}"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"/>
                                                </Border>
                                            </Grid>

                                            <!-- Meta row -->
                                            <WrapPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding DetectedAt,
                                                                   StringFormat='{}{0:HH:mm:ss} UTC'}"
                                                           FontSize="11"
                                                           Foreground="#6B6F82"
                                                           Margin="0,0,14,0"/>
                                                <TextBlock Text="{Binding Confidence,
                                                                   StringFormat='Confidence: {0:P0}'}"
                                                           FontSize="11"
                                                           Foreground="#6B6F82"
                                                           Margin="0,0,14,0"/>
                                                <TextBlock Text="{Binding RelatedEvents.Count,
                                                                   StringFormat='{}{0} related events'}"
                                                           FontSize="11"
                                                           Foreground="#6B6F82"/>
                                            </WrapPanel>

                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════════════════════
                 Row 5 — Event Correlations
                 ══════════════════════════════════════════════════════ -->
            <Border Background="#181C26"
                    CornerRadius="12"
                    Padding="16"
                    BorderBrush="#2E3348"
                    BorderThickness="1"
                    IsVisible="{Binding HasData}">
                <StackPanel Spacing="12">

                    <!-- Header -->
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock Text="Event Correlations"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#FFFFFF"/>
                            <Border Background="#2E3348"
                                    CornerRadius="10"
                                    Padding="9,3"
                                    VerticalAlignment="Center"
                                    IsVisible="{Binding HasCorrelations}">
                                <TextBlock Text="{Binding CorrelationCount, StringFormat='{}{0} groups'}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#E8E9ED"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Empty state -->
                    <StackPanel Orientation="Horizontal"
                                Spacing="10"
                                IsVisible="{Binding NoCorrelations}">
                        <TextBlock Text="○"
                                   FontSize="16"
                                   Foreground="#6B6F82"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="No event correlations detected."
                                   FontSize="13"
                                   Foreground="#A0A4B8"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Correlation cards (expandable) -->
                    <ItemsControl x:CompileBindings="False"
                                  ItemsSource="{Binding Correlations}"
                                  IsVisible="{Binding HasCorrelations}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#101318"
                                        CornerRadius="8"
                                        Margin="0,0,0,6"
                                        BorderBrush="#2E3348"
                                        BorderThickness="1">
                                    <Expander>
                                        <!-- ── Expander header ── -->
                                        <Expander.Header>
                                            <Grid ColumnDefinitions="*,Auto" Margin="4,0">
                                                <StackPanel Spacing="4">
                                                    <!-- Name + type badge -->
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#FFFFFF"
                                                                   VerticalAlignment="Center"/>
                                                        <Border CornerRadius="4"
                                                                Padding="7,2"
                                                                VerticalAlignment="Center"
                                                                Background="{Binding CorrelationType,
                                                                             Converter={StaticResource CorrelationTypeToColorConverter}}">
                                                            <TextBlock Text="{Binding CorrelationType}"
                                                                       FontSize="10"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="White"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <!-- Description -->
                                                    <TextBlock Text="{Binding Description}"
                                                               FontSize="12"
                                                               Foreground="#A0A4B8"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>

                                                <!-- Right-side meta -->
                                                <StackPanel Grid.Column="1"
                                                            Orientation="Vertical"
                                                            HorizontalAlignment="Right"
                                                            Spacing="4"
                                                            Margin="12,0,4,0">
                                                    <TextBlock Text="{Binding EventEntries.Count,
                                                                       StringFormat='{}{0} events'}"
                                                               FontSize="11"
                                                               Foreground="#6B6F82"
                                                               HorizontalAlignment="Right"/>
                                                    <TextBlock Text="{Binding DetectedAt,
                                                                       StringFormat='{}{0:HH:mm:ss} UTC'}"
                                                               FontSize="11"
                                                               Foreground="#6B6F82"
                                                               HorizontalAlignment="Right"/>
                                                </StackPanel>
                                            </Grid>
                                        </Expander.Header>

                                        <!-- ── Expanded: related events list ── -->
                                        <Border Background="#0E1118"
                                                CornerRadius="0,0,8,8"
                                                Padding="12,8">
                                            <StackPanel Spacing="4">
                                                <!-- Column headers -->
                                                <Grid ColumnDefinitions="70,60,180,*,90"
                                                      Margin="0,0,0,4">
                                                    <TextBlock Text="Level"      FontSize="10" FontWeight="SemiBold" Foreground="#6B6F82"/>
                                                    <TextBlock Text="EventId"    FontSize="10" FontWeight="SemiBold" Foreground="#6B6F82" Grid.Column="1"/>
                                                    <TextBlock Text="Source"     FontSize="10" FontWeight="SemiBold" Foreground="#6B6F82" Grid.Column="2"/>
                                                    <TextBlock Text="Message"    FontSize="10" FontWeight="SemiBold" Foreground="#6B6F82" Grid.Column="3"/>
                                                    <TextBlock Text="Time"       FontSize="10" FontWeight="SemiBold" Foreground="#6B6F82" Grid.Column="4"/>
                                                </Grid>
                                                <ItemsControl x:CompileBindings="False"
                                                              ItemsSource="{Binding EventEntries}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid ColumnDefinitions="70,60,180,*,90"
                                                                  Margin="0,2">
                                                                <TextBlock Text="{Binding Level}"
                                                                           FontSize="11"
                                                                           Foreground="#E8E9ED"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding EventId}"
                                                                           FontSize="11"
                                                                           Foreground="#A0A4B8"
                                                                           Grid.Column="1"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding Source}"
                                                                           FontSize="11"
                                                                           Foreground="#A0A4B8"
                                                                           Grid.Column="2"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding Message}"
                                                                           FontSize="11"
                                                                           Foreground="#6B6F82"
                                                                           Grid.Column="3"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding TimeCreated,
                                                                                   StringFormat='{}{0:HH:mm:ss}'}"
                                                                           FontSize="11"
                                                                           Foreground="#6B6F82"
                                                                           Grid.Column="4"
                                                                           VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </Expander>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
