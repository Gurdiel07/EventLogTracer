<Window xmlns="https://github.com/avaloniaui"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:vm="using:EventLogTracer.App.ViewModels"
       xmlns:views="using:EventLogTracer.App.Views"
       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
       mc:Ignorable="d"
       x:Class="EventLogTracer.App.Views.MainWindow"
       x:DataType="vm:MainWindowViewModel"
       Title="Event Log Tracer"
       Width="1280" Height="800"
       MinWidth="900" MinHeight="600"
       WindowStartupLocation="CenterScreen"
       Background="#F2F4F7"
       FontFamily="Inter"
       KeyDown="OnWindowKeyDown">

    <Grid RowDefinitions="*,Auto">

        <Grid Grid.Row="0" ColumnDefinitions="220,*">

            <!-- Sidebar -->
            <Border Grid.Column="0"
                    Background="#FFFFFF"
                    BorderBrush="#DFE4EB"
                    BorderThickness="0,0,1,0">
                <DockPanel>

                    <StackPanel DockPanel.Dock="Top" Margin="16,20,16,16">
                        <TextBlock Text="⚡ Event Log Tracer"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="#111827" LetterSpacing="-0.5"/>
                        <TextBlock Text="Real-time Windows Event Analysis"
                                   FontSize="11" Foreground="#6B7280" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Top" Margin="8,0">

                        <Button Classes="nav-btn"
                                Classes.active="{Binding IsDashboardSelected}"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="Dashboard">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="⬛" FontSize="14"/>
                                <TextBlock Text="Dashboard"/>
                            </StackPanel>
                        </Button>

                        <Button Classes="nav-btn"
                                Classes.active="{Binding IsEventViewerSelected}"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="EventViewer">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="📋" FontSize="14"/>
                                <TextBlock Text="Event Viewer"/>
                                <Border Background="#EAF2FB"
                                        CornerRadius="100" Padding="8,2"
                                        BorderBrush="#DFE4EB" BorderThickness="1"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TotalEventCount}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="#1160AD"/>
                                </Border>
                            </StackPanel>
                        </Button>

                        <Button Classes="nav-btn"
                                Classes.active="{Binding IsTimelineSelected}"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="Timeline">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="📅" FontSize="14"/>
                                <TextBlock Text="Timeline"/>
                            </StackPanel>
                        </Button>

                        <Button Classes="nav-btn"
                                Classes.active="{Binding IsAlertsSelected}"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="Alerts">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="🔔" FontSize="14"/>
                                <TextBlock Text="Alerts"/>
                            </StackPanel>
                        </Button>

                        <Button Classes="nav-btn"
                                Classes.active="{Binding IsSearchSelected}"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="Search">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="🔍" FontSize="14"/>
                                <TextBlock Text="Search"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom" Margin="8,0,8,12">
                        <Separator Margin="4,8" Background="#DFE4EB"/>
                        <Button Classes="nav-btn"
                                Classes.active="{Binding IsSettingsSelected}"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="Settings">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="⚙️" FontSize="14"/>
                                <TextBlock Text="Settings"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="#F2F4F7">
                <ContentControl Content="{Binding CurrentPage}">
                    <ContentControl.DataTemplates>
                        <DataTemplate DataType="vm:DashboardViewModel">
                            <views:DashboardView/>
                        </DataTemplate>
                        <DataTemplate DataType="vm:EventViewerViewModel">
                            <views:EventViewerView/>
                        </DataTemplate>
                        <DataTemplate DataType="vm:TimelineViewModel">
                            <views:TimelineView/>
                        </DataTemplate>
                        <DataTemplate DataType="vm:AlertsViewModel">
                            <views:AlertsView/>
                        </DataTemplate>
                        <DataTemplate DataType="vm:SearchViewModel">
                            <views:SearchView/>
                        </DataTemplate>
                        <DataTemplate DataType="vm:SettingsViewModel">
                            <views:SettingsView/>
                        </DataTemplate>
                    </ContentControl.DataTemplates>
                </ContentControl>
            </Border>

        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="1"
                Background="#FFFFFF"
                BorderBrush="#DFE4EB"
                BorderThickness="0,1,0,0"
                Padding="16,5">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">

                <Border Grid.Column="0"
                        Background="#F2F4F7" CornerRadius="100"
                        Padding="5,14" BorderBrush="#DFE4EB" BorderThickness="1"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Panel Width="9" Height="9" VerticalAlignment="Center">
                            <Ellipse Width="13" Height="13" Fill="#16A34A" Opacity="0.2" IsVisible="{Binding IsMonitoring}"/>
                            <Ellipse Width="9" Height="9" Fill="#16A34A" IsVisible="{Binding IsMonitoring}"/>
                            <Ellipse Width="9" Height="9" Fill="#DC2626" IsVisible="{Binding !IsMonitoring}"/>
                        </Panel>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#6B7280"
                                   FontSize="13" FontWeight="Medium"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <TextBlock Grid.Column="1"
                           Text="{Binding LastEventInfo}"
                           Foreground="#9CA3AF" FontSize="12"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" Margin="0,0,16,0">
                    <TextBlock Text="Events:" Foreground="#6B7280" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalEventCount}"
                               Foreground="#111827" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="3"
                        Classes.btn-primary="{Binding !IsMonitoring}"
                        Classes.btn-danger="{Binding IsMonitoring}"
                        Content="{Binding ToggleButtonText}"
                        Command="{Binding ToggleMonitoringCommand}"
                        Padding="18,5" FontSize="12" FontWeight="Medium" CornerRadius="8"/>

            </Grid>
        </Border>

    </Grid>
</Window>
