<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EventLogTracer.App.ViewModels"
        xmlns:views="using:EventLogTracer.App.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="EventLogTracer.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Event Log Tracer"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#0C111B"
        KeyDown="OnWindowKeyDown">

    <Window.Styles>
        <Style Selector="Button.nav-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E8E9ED"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Margin" Value="4,2"/>
        </Style>
        <Style Selector="Button.nav-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#131A28"/>
        </Style>
        <Style Selector="Button.nav-btn.active">
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
        <Style Selector="Button.nav-btn.active /template/ ContentPresenter">
            <Setter Property="Background" Value="#3b82f6"/>
        </Style>
        <Style Selector="Button.nav-btn.active:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3b82f6"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="*,Auto">

        <Grid Grid.Row="0" ColumnDefinitions="220,*">

            <!-- ── Sidebar with gradient ── -->
            <Border Grid.Column="0"
                    BorderBrush="#1E3A5F"
                    BorderThickness="0,0,1,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#0B1628" Offset="0"/>
                        <GradientStop Color="#0F1D32" Offset="0.5"/>
                        <GradientStop Color="#0B1628" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel>

                    <StackPanel DockPanel.Dock="Top" Margin="16,20,16,16">
                        <TextBlock Text="⚡ Event Log Tracer"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#F0F4FF"/>
                        <TextBlock Text="Real-time Windows Event Analysis"
                                   FontSize="11"
                                   Foreground="#4A5670"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Top" Margin="8,0">

                        <Button Classes="nav-btn"
                                Classes.active="{Binding IsDashboardSelected}"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="Dashboard">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="⬛" FontSize="14"/>
                                <TextBlock Text="Dashboard"/>
                            </StackPanel>
                        </Button>

                        <Button Classes="nav-btn"
                                Classes.active="{Binding IsEventViewerSelected}"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="EventViewer">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="📋" FontSize="14"/>
                                <TextBlock Text="Event Viewer"/>
                                <Border Background="#1A2744"
                                        CornerRadius="9"
                                        Padding="6,1"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TotalEventCount, StringFormat='[{0}]'}"
                                               FontSize="10"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </Button>

                        <Button Classes="nav-btn"
                                Classes.active="{Binding IsTimelineSelected}"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="Timeline">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="📅" FontSize="14"/>
                                <TextBlock Text="Timeline"/>
                            </StackPanel>
                        </Button>

                        <Button Classes="nav-btn"
                                Classes.active="{Binding IsAlertsSelected}"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="Alerts">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="🔔" FontSize="14"/>
                                <TextBlock Text="Alerts"/>
                            </StackPanel>
                        </Button>

                        <Button Classes="nav-btn"
                                Classes.active="{Binding IsSearchSelected}"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="Search">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="🔍" FontSize="14"/>
                                <TextBlock Text="Search"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom" Margin="8,0,8,12">
                        <Separator Margin="4,8" Background="#1E3A5F"/>
                        <Button Classes="nav-btn"
                                Classes.active="{Binding IsSettingsSelected}"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="Settings">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="⚙️" FontSize="14"/>
                                <TextBlock Text="Settings"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                </DockPanel>
            </Border>

            <!-- ── Content area ── -->
            <Border Grid.Column="1" Background="#0C111B">
                <ContentControl Content="{Binding CurrentPage}">
                    <ContentControl.DataTemplates>
                        <DataTemplate DataType="vm:DashboardViewModel">
                            <views:DashboardView/>
                        </DataTemplate>
                        <DataTemplate DataType="vm:EventViewerViewModel">
                            <views:EventViewerView/>
                        </DataTemplate>
                        <DataTemplate DataType="vm:TimelineViewModel">
                            <views:TimelineView/>
                        </DataTemplate>
                        <DataTemplate DataType="vm:AlertsViewModel">
                            <views:AlertsView/>
                        </DataTemplate>
                        <DataTemplate DataType="vm:SearchViewModel">
                            <views:SearchView/>
                        </DataTemplate>
                        <DataTemplate DataType="vm:SettingsViewModel">
                            <views:SettingsView/>
                        </DataTemplate>
                    </ContentControl.DataTemplates>
                </ContentControl>
            </Border>

        </Grid>

        <!-- ═══ Status bar ═══ -->
        <Border Grid.Row="1"
                Background="#080C16"
                BorderBrush="#1E3A5F"
                BorderThickness="0,1,0,0"
                Padding="16,6">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                    <Panel Width="8" Height="8" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="#00C851" IsVisible="{Binding IsMonitoring}"/>
                        <Ellipse Width="8" Height="8" Fill="#FF4444" IsVisible="{Binding !IsMonitoring}"/>
                    </Panel>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="#8899B4"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding LastEventInfo}"
                           Foreground="#4A5670"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" Margin="0,0,16,0">
                    <TextBlock Text="Events:" Foreground="#4A5670" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalEventCount}"
                               Foreground="#E8E9ED"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="3"
                        Content="{Binding ToggleButtonText}"
                        Command="{Binding ToggleMonitoringCommand}"
                        Padding="12,4"
                        FontSize="12"
                        CornerRadius="4"/>

            </Grid>
        </Border>

    </Grid>
</Window>
