<Window xmlns="https://github.com/avaloniaui"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:vm="using:EventLogTracer.App.ViewModels"
       xmlns:views="using:EventLogTracer.App.Views"
       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
       mc:Ignorable="d"
       x:Class="EventLogTracer.App.Views.MainWindow"
       x:DataType="vm:MainWindowViewModel"
       Title="Event Log Tracer"
       Width="1280" Height="800"
       MinWidth="900" MinHeight="600"
       WindowStartupLocation="CenterScreen"
       Background="#151A2E"
       FontFamily="Inter"
       KeyDown="OnWindowKeyDown">

    <Grid RowDefinitions="*,Auto">

        <Grid Grid.Row="0" ColumnDefinitions="220,*">

            <!-- Sidebar -->
            <Border Grid.Column="0"
                    BorderBrush="#3D4563"
                    BorderThickness="0,0,1,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#0F1628" Offset="0"/>
                        <GradientStop Color="#131B30" Offset="0.5"/>
                        <GradientStop Color="#0F1628" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel>

                    <StackPanel DockPanel.Dock="Top" Margin="16,20,16,16">
                        <TextBlock Text="⚡ Event Log Tracer"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#E8E9F0"
                                   LetterSpacing="-0.5"/>
                        <TextBlock Text="Real-time Windows Event Analysis"
                                   FontSize="11"
                                   Foreground="#585E72"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Top" Margin="8,0">

                        <Button Classes="nav-btn"
                                Classes.active="{Binding IsDashboardSelected}"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="Dashboard">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="⬛" FontSize="14"/>
                                <TextBlock Text="Dashboard"/>
                            </StackPanel>
                        </Button>

                        <Button Classes="nav-btn"
                                Classes.active="{Binding IsEventViewerSelected}"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="EventViewer">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="📋" FontSize="14"/>
                                <TextBlock Text="Event Viewer"/>
                                <Border Background="#262C44"
                                        CornerRadius="100"
                                        Padding="8,2"
                                        BorderBrush="#3D4563"
                                        BorderThickness="1"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TotalEventCount}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="#60A5FA"/>
                                </Border>
                            </StackPanel>
                        </Button>

                        <Button Classes="nav-btn"
                                Classes.active="{Binding IsTimelineSelected}"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="Timeline">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="📅" FontSize="14"/>
                                <TextBlock Text="Timeline"/>
                            </StackPanel>
                        </Button>

                        <Button Classes="nav-btn"
                                Classes.active="{Binding IsAlertsSelected}"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="Alerts">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="🔔" FontSize="14"/>
                                <TextBlock Text="Alerts"/>
                            </StackPanel>
                        </Button>

                        <Button Classes="nav-btn"
                                Classes.active="{Binding IsSearchSelected}"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="Search">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="🔍" FontSize="14"/>
                                <TextBlock Text="Search"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom" Margin="8,0,8,12">
                        <Separator Margin="4,8" Background="#3D4563"/>
                        <Button Classes="nav-btn"
                                Classes.active="{Binding IsSettingsSelected}"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="Settings">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="⚙️" FontSize="14"/>
                                <TextBlock Text="Settings"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="#151A2E">
                <ContentControl Content="{Binding CurrentPage}">
                    <ContentControl.DataTemplates>
                        <DataTemplate DataType="vm:DashboardViewModel">
                            <views:DashboardView/>
                        </DataTemplate>
                        <DataTemplate DataType="vm:EventViewerViewModel">
                            <views:EventViewerView/>
                        </DataTemplate>
                        <DataTemplate DataType="vm:TimelineViewModel">
                            <views:TimelineView/>
                        </DataTemplate>
                        <DataTemplate DataType="vm:AlertsViewModel">
                            <views:AlertsView/>
                        </DataTemplate>
                        <DataTemplate DataType="vm:SearchViewModel">
                            <views:SearchView/>
                        </DataTemplate>
                        <DataTemplate DataType="vm:SettingsViewModel">
                            <views:SettingsView/>
                        </DataTemplate>
                    </ContentControl.DataTemplates>
                </ContentControl>
            </Border>

        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="1"
                Background="#0F1320"
                BorderBrush="#3D4563"
                BorderThickness="0,1,0,0"
                Padding="16,5">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">

                <Border Grid.Column="0"
                        Background="#2F3650" CornerRadius="100"
                        Padding="5,14" BorderBrush="#3D4563" BorderThickness="1"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Panel Width="9" Height="9" VerticalAlignment="Center">
                            <Ellipse Width="13" Height="13" Fill="#22C55E" Opacity="0.2" IsVisible="{Binding IsMonitoring}"/>
                            <Ellipse Width="9" Height="9" Fill="#22C55E" IsVisible="{Binding IsMonitoring}"/>
                            <Ellipse Width="9" Height="9" Fill="#EF4444" IsVisible="{Binding !IsMonitoring}"/>
                        </Panel>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#9BA2BE"
                                   FontSize="13" FontWeight="Medium"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <TextBlock Grid.Column="1"
                           Text="{Binding LastEventInfo}"
                           Foreground="#767C96"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" Margin="0,0,16,0">
                    <TextBlock Text="Events:" Foreground="#767C96" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalEventCount}"
                               Foreground="#E8E9F0"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="3"
                        Classes.btn-primary="{Binding !IsMonitoring}"
                        Classes.btn-danger="{Binding IsMonitoring}"
                        Content="{Binding ToggleButtonText}"
                        Command="{Binding ToggleMonitoringCommand}"
                        Padding="18,5"
                        FontSize="12"
                        FontWeight="Medium"
                        CornerRadius="8"/>

            </Grid>
        </Border>

    </Grid>
</Window>
