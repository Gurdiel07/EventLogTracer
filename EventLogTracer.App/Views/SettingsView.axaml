<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EventLogTracer.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="EventLogTracer.App.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             FontFamily="Inter">

    <ScrollViewer>
        <StackPanel Margin="24" Spacing="16" MaxWidth="820">

            <TextBlock Text="Settings" FontSize="28" FontWeight="Bold" Foreground="#111827" LetterSpacing="-1" Margin="0,0,0,8"/>

            <!-- Export -->
            <Border Background="#FFFFFF" CornerRadius="16" Padding="20" BorderBrush="#DFE4EB" BorderThickness="1">
                <StackPanel Spacing="16">
                    <TextBlock Text="Export Events" FontSize="14" FontWeight="SemiBold" Foreground="#111827" LetterSpacing="-0.15"/>
                    <Border Height="1" Background="#DFE4EB" Margin="0,-4,0,0"/>
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="6"><TextBlock Text="Format" FontSize="13" FontWeight="Medium" Foreground="#6B7280"/><ComboBox x:CompileBindings="False" ItemsSource="{Binding FormatOptions}" SelectedItem="{Binding ExportFormat}" HorizontalAlignment="Left" Width="220"/></StackPanel>
                        <StackPanel Spacing="6"><TextBlock Text="From Date" FontSize="13" FontWeight="Medium" Foreground="#6B7280"/><CalendarDatePicker SelectedDate="{Binding ExportDateFrom}" Watermark="No start filter" HorizontalAlignment="Left" Width="220"/></StackPanel>
                        <StackPanel Spacing="6"><TextBlock Text="To Date" FontSize="13" FontWeight="Medium" Foreground="#6B7280"/><CalendarDatePicker SelectedDate="{Binding ExportDateTo}" Watermark="No end filter" HorizontalAlignment="Left" Width="220"/></StackPanel>
                        <StackPanel Spacing="6"><TextBlock Text="Level Filter" FontSize="13" FontWeight="Medium" Foreground="#6B7280"/><ComboBox x:CompileBindings="False" ItemsSource="{Binding LevelFilterOptions}" SelectedItem="{Binding ExportLevelFilter}" HorizontalAlignment="Left" Width="220"/></StackPanel>
                        <StackPanel Spacing="6"><TextBlock Text="Output Folder" FontSize="13" FontWeight="Medium" Foreground="#6B7280"/><TextBox Text="{Binding ExportPath}" Padding="10,7"/></StackPanel>
                    </StackPanel>
                    <TextBlock Text="{Binding ExportEventCount, StringFormat='~{0} events will be exported'}" Foreground="#6B7280" FontSize="12" IsVisible="{Binding ExportEventCount, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Preview Count" Command="{Binding PreviewExportCommand}" Padding="14,8"/>
                        <Button Classes="btn-primary" Content="Export" Command="{Binding ExecuteExportCommand}" IsEnabled="{Binding !IsExporting}" Padding="14,8"/>
                        <Button Content="Open Folder" Command="{Binding OpenExportFolderCommand}" Padding="14,8"/>
                    </StackPanel>
                    <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsExporting}" Height="2" Background="Transparent" Margin="0,2,0,0"/>
                    <TextBlock Text="{Binding ExportStatusMessage}" Foreground="#16A34A" FontSize="12" TextWrapping="Wrap" IsVisible="{Binding ExportStatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>
            </Border>

            <!-- Database -->
            <Border Background="#FFFFFF" CornerRadius="16" Padding="20" BorderBrush="#DFE4EB" BorderThickness="1">
                <StackPanel Spacing="16">
                    <TextBlock Text="Database Management" FontSize="14" FontWeight="SemiBold" Foreground="#111827" LetterSpacing="-0.15"/>
                    <Border Height="1" Background="#DFE4EB" Margin="0,-4,0,0"/>
                    <Border Background="#F8FAFC" CornerRadius="10" BorderBrush="#DFE4EB" BorderThickness="1">
                        <StackPanel>
                            <Border Padding="14,11"><Grid ColumnDefinitions="160,*"><TextBlock Text="Database Path" FontSize="13" FontWeight="Medium" Foreground="#6B7280" VerticalAlignment="Center"/><TextBox Grid.Column="1" Text="{Binding DatabasePath}" IsReadOnly="True" Foreground="#9CA3AF" Padding="6,4" FontSize="11" FontFamily="Consolas, Menlo, monospace" HorizontalAlignment="Right"/></Grid></Border>
                            <Border Height="1" Background="#DFE4EB"/>
                            <Border Padding="14,11"><Grid ColumnDefinitions="160,*"><TextBlock Text="Database Size" FontSize="13" FontWeight="Medium" Foreground="#6B7280" VerticalAlignment="Center"/><TextBlock Grid.Column="1" Text="{Binding DatabaseSize}" Foreground="#111827" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid></Border>
                            <Border Height="1" Background="#DFE4EB"/>
                            <Border Padding="14,11"><Grid ColumnDefinitions="160,*"><TextBlock Text="Total Events" FontSize="13" FontWeight="Medium" Foreground="#6B7280" VerticalAlignment="Center"/><TextBlock Grid.Column="1" Text="{Binding TotalEventsInDb, StringFormat='{}{0:N0}'}" Foreground="#111827" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid></Border>
                            <Border Height="1" Background="#DFE4EB"/>
                            <Border Padding="14,11"><Grid ColumnDefinitions="160,*"><TextBlock Text="Saved Queries" FontSize="13" FontWeight="Medium" Foreground="#6B7280" VerticalAlignment="Center"/><TextBlock Grid.Column="1" Text="{Binding TotalSavedQueries}" Foreground="#111827" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid></Border>
                            <Border Height="1" Background="#DFE4EB"/>
                            <Border Padding="14,11"><Grid ColumnDefinitions="160,*"><TextBlock Text="Alert Rules" FontSize="13" FontWeight="Medium" Foreground="#6B7280" VerticalAlignment="Center"/><TextBlock Grid.Column="1" Text="{Binding TotalAlertRules}" Foreground="#111827" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid></Border>
                        </StackPanel>
                    </Border>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Refresh Stats" Command="{Binding RefreshStatsCommand}" Padding="14,8"/>
                        <Button Content="Compact Database" Command="{Binding VacuumDatabaseCommand}" Padding="14,8" ToolTip.Tip="Run VACUUM to reclaim unused space"/>
                        <Button Classes="btn-danger" Content="Clear Old Events (30d)" Command="{Binding ClearOldEventsCommand}" Padding="14,8" ToolTip.Tip="Delete events older than 30 days"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- About -->
            <Border Background="#FFFFFF" CornerRadius="16" Padding="20" BorderBrush="#DFE4EB" BorderThickness="1">
                <StackPanel Spacing="16">
                    <TextBlock Text="About" FontSize="14" FontWeight="SemiBold" Foreground="#111827" LetterSpacing="-0.15"/>
                    <Border Height="1" Background="#DFE4EB" Margin="0,-4,0,0"/>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Event Log Tracer" FontSize="16" FontWeight="Bold" Foreground="#111827" LetterSpacing="-0.5"/>
                        <TextBlock Text="{Binding AppVersion, StringFormat='Version {0}'}" FontSize="13" Foreground="#6B7280"/>
                    </StackPanel>
                    <TextBlock Text="Windows Event Log analysis, monitoring, and alerting tool." Foreground="#6B7280" FontSize="13" TextWrapping="Wrap"/>
                    <Border Background="#F8FAFC" CornerRadius="10" BorderBrush="#DFE4EB" BorderThickness="1">
                        <StackPanel>
                            <Border Padding="14,11"><Grid ColumnDefinitions="140,*"><TextBlock Text="Framework" FontSize="13" FontWeight="Medium" Foreground="#6B7280"/><TextBlock Grid.Column="1" Text=".NET 8 + Avalonia UI 11" Foreground="#9CA3AF" FontSize="13" HorizontalAlignment="Right"/></Grid></Border>
                            <Border Height="1" Background="#DFE4EB"/>
                            <Border Padding="14,11"><Grid ColumnDefinitions="140,*"><TextBlock Text="MVVM" FontSize="13" FontWeight="Medium" Foreground="#6B7280"/><TextBlock Grid.Column="1" Text="CommunityToolkit.Mvvm" Foreground="#9CA3AF" FontSize="13" HorizontalAlignment="Right"/></Grid></Border>
                            <Border Height="1" Background="#DFE4EB"/>
                            <Border Padding="14,11"><Grid ColumnDefinitions="140,*"><TextBlock Text="Database" FontSize="13" FontWeight="Medium" Foreground="#6B7280"/><TextBlock Grid.Column="1" Text="EF Core 8 + SQLite" Foreground="#9CA3AF" FontSize="13" HorizontalAlignment="Right"/></Grid></Border>
                            <Border Height="1" Background="#DFE4EB"/>
                            <Border Padding="14,11"><Grid ColumnDefinitions="140,*"><TextBlock Text="Charts" FontSize="13" FontWeight="Medium" Foreground="#6B7280"/><TextBlock Grid.Column="1" Text="LiveCharts2 (SkiaSharp)" Foreground="#9CA3AF" FontSize="13" HorizontalAlignment="Right"/></Grid></Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
