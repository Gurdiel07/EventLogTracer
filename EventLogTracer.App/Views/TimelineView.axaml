<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EventLogTracer.App.ViewModels"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="EventLogTracer.App.Views.TimelineView"
             x:DataType="vm:TimelineViewModel"
             x:Name="Root">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="24,24,24,12">

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Timeline"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#FFFFFF"/>
            <TextBlock Text="Interactive event visualization with zoom and navigation"
                       FontSize="12"
                       Foreground="#888888"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Toolbar -->
        <StackPanel Grid.Row="1" Spacing="8" Margin="0,0,0,10">
            <WrapPanel Orientation="Horizontal">
                <Button Content="Back"
                        Command="{Binding NavigateBackwardCommand}"
                        Padding="10,6"
                        CornerRadius="4"/>
                <Button Content="Go to Now"
                        Command="{Binding GoToNowCommand}"
                        Padding="10,6"
                        CornerRadius="4"
                        Margin="4,0,0,0"/>
                <Button Content="Forward"
                        Command="{Binding NavigateForwardCommand}"
                        Padding="10,6"
                        CornerRadius="4"
                        Margin="4,0,0,0"/>

                <Button Content="Zoom +"
                        Command="{Binding ZoomInCommand}"
                        Padding="10,6"
                        CornerRadius="4"
                        Margin="12,0,0,0"/>
                <Button Content="Zoom -"
                        Command="{Binding ZoomOutCommand}"
                        Padding="10,6"
                        CornerRadius="4"
                        Margin="4,0,0,0"/>
                <Button Content="Reset"
                        Command="{Binding ResetZoomCommand}"
                        Padding="10,6"
                        CornerRadius="4"
                        Margin="4,0,0,0"/>

                <StackPanel Orientation="Horizontal" Spacing="6" Margin="12,0,0,0">
                    <TextBlock Text="Level:" Foreground="#999999" FontSize="12" VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding LevelOptions}"
                              SelectedItem="{Binding SelectedLevel}"
                              Width="140"
                              Background="#2D2D2D"
                              Foreground="#FFFFFF"
                              CornerRadius="4"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="6" Margin="12,0,0,0">
                    <TextBlock Text="Log:" Foreground="#999999" FontSize="12" VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding LogNameOptions}"
                              SelectedItem="{Binding SelectedLogName}"
                              Width="170"
                              Background="#2D2D2D"
                              Foreground="#FFFFFF"
                              CornerRadius="4"/>
                </StackPanel>

                <Button Content="Refresh"
                        Command="{Binding LoadTimelineCommand}"
                        Padding="10,6"
                        CornerRadius="4"
                        Margin="12,0,0,0"/>
            </WrapPanel>

            <WrapPanel Orientation="Horizontal">
                <TextBlock Text="{Binding TotalVisible, StringFormat='Showing {0} events |'}"
                           FontSize="12"
                           Foreground="#888888"/>
                <TextBlock Text="{Binding VisibleRangeStart, StringFormat='{}{0:MMM dd HH:mm}'}"
                           FontSize="12"
                           Foreground="#888888"/>
                <TextBlock Text=" - "
                           FontSize="12"
                           Foreground="#888888"/>
                <TextBlock Text="{Binding VisibleRangeEnd, StringFormat='{}{0:MMM dd HH:mm}'}"
                           FontSize="12"
                           Foreground="#888888"/>
                <TextBlock Text="{Binding ZoomLevel, StringFormat=' | Zoom {0:0.##}x'}"
                           FontSize="12"
                           Foreground="#666666"
                           Margin="8,0,0,0"/>
            </WrapPanel>

            <ProgressBar IsIndeterminate="True"
                         IsVisible="{Binding IsLoading}"
                         Height="2"
                         Background="Transparent"/>
        </StackPanel>

        <!-- Chart -->
        <Border Grid.Row="2"
                Background="#222222"
                BorderBrush="#2A2A2A"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Margin="0,0,0,0">
            <lvc:CartesianChart x:CompileBindings="False"
                                Series="{Binding TimelineSeries}"
                                XAxes="{Binding TimelineXAxes}"
                                YAxes="{Binding TimelineYAxes}"
                                ChartPointPointerDownCommand="{Binding SelectChartPointCommand}"
                                ZoomMode="X"
                                TooltipPosition="Top"
                                Background="Transparent"
                                MinHeight="360"/>
        </Border>

        <!-- Detail panel -->
        <Border Grid.Row="3"
                Background="#141414"
                BorderBrush="#2A2A2A"
                BorderThickness="0,1,0,0"
                CornerRadius="0,0,6,6"
                IsVisible="{Binding SelectedEventDetail, Converter={x:Static ObjectConverters.IsNotNull}}">

            <ScrollViewer MaxHeight="270" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20,16" Spacing="14">

                    <WrapPanel Orientation="Horizontal">
                        <StackPanel Width="120" Margin="0,0,16,8">
                            <TextBlock Text="Event ID" FontSize="10" Foreground="#666666"/>
                            <TextBlock Text="{Binding SelectedEventDetail.EventId}"
                                       FontSize="15" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                        </StackPanel>

                        <StackPanel Width="130" Margin="0,0,16,8">
                            <TextBlock Text="Level" FontSize="10" Foreground="#666666"/>
                            <Border CornerRadius="4" Padding="10,3" HorizontalAlignment="Left" Margin="0,2,0,0"
                                    x:CompileBindings="False"
                                    Background="{Binding SelectedEventDetail.Level,
                                                 Converter={StaticResource LevelBgConverter},
                                                 ConverterParameter=badge}">
                                <TextBlock Text="{Binding SelectedEventDetail.Level}"
                                           FontSize="12" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                            </Border>
                        </StackPanel>

                        <StackPanel MinWidth="200" Margin="0,0,16,8">
                            <TextBlock Text="Source" FontSize="10" Foreground="#666666"/>
                            <TextBlock Text="{Binding SelectedEventDetail.Source}"
                                       FontSize="13" Foreground="#CCCCCC"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,16,8">
                            <TextBlock Text="Time Created" FontSize="10" Foreground="#666666"/>
                            <TextBlock Text="{Binding SelectedEventDetail.TimeCreated, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss.fff}'}"
                                       FontSize="13" Foreground="#CCCCCC"/>
                        </StackPanel>
                    </WrapPanel>

                    <WrapPanel Orientation="Horizontal">
                        <StackPanel Width="120" Margin="0,0,16,8">
                            <TextBlock Text="Log Name" FontSize="10" Foreground="#666666"/>
                            <TextBlock Text="{Binding SelectedEventDetail.LogName}"
                                       FontSize="13" Foreground="#CCCCCC"/>
                        </StackPanel>
                        <StackPanel Width="160" Margin="0,0,16,8">
                            <TextBlock Text="Machine" FontSize="10" Foreground="#666666"/>
                            <TextBlock Text="{Binding SelectedEventDetail.MachineName}"
                                       FontSize="13" Foreground="#CCCCCC"/>
                        </StackPanel>
                        <StackPanel Width="140" Margin="0,0,16,8">
                            <TextBlock Text="Category" FontSize="10" Foreground="#666666"/>
                            <TextBlock Text="{Binding SelectedEventDetail.Category, FallbackValue='-'}"
                                       FontSize="13" Foreground="#CCCCCC"/>
                        </StackPanel>
                        <StackPanel Width="180" Margin="0,0,16,8">
                            <TextBlock Text="User ID" FontSize="10" Foreground="#666666"/>
                            <TextBlock Text="{Binding SelectedEventDetail.UserId, FallbackValue='-'}"
                                       FontSize="13" Foreground="#CCCCCC"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,8">
                            <TextBlock Text="Keywords" FontSize="10" Foreground="#666666"/>
                            <TextBlock Text="{Binding SelectedEventDetail.Keywords, FallbackValue='-'}"
                                       FontSize="13" Foreground="#CCCCCC"/>
                        </StackPanel>
                    </WrapPanel>

                    <!-- ── Tags (interactive chips) ── -->
                    <StackPanel Spacing="6">
                        <ItemsControl x:CompileBindings="False"
                                      ItemsSource="{Binding SelectedEventTags}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#2D2D2D" CornerRadius="10"
                                            Padding="8,3" Margin="0,0,6,4">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="{Binding}"
                                                       Foreground="#CCCCCC"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"/>
                                            <Button Content="✕"
                                                    Command="{Binding #Root.DataContext.RemoveTagCommand}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Foreground="#666666"
                                                    FontSize="9"
                                                    Padding="2,0"
                                                    Cursor="Hand"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <!-- Add tag input -->
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBox Text="{Binding NewTagText}"
                                     Watermark="Add tag…"
                                     Width="160"
                                     FontSize="12"
                                     Padding="7,4"
                                     Background="#222222"
                                     Foreground="#FFFFFF"
                                     CornerRadius="4"/>
                            <Button Content="Add Tag"
                                    Command="{Binding AddTagCommand}"
                                    IsEnabled="{Binding NewTagText,
                                                Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                    Padding="10,4"
                                    FontSize="12"
                                    CornerRadius="4"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Message" FontSize="10" Foreground="#666666"/>
                        <Border Background="#111111" CornerRadius="4" Padding="12,10"
                                BorderBrush="#2A2A2A" BorderThickness="1">
                            <ScrollViewer MaxHeight="80" VerticalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding SelectedEventDetail.Message}"
                                           TextWrapping="Wrap"
                                           Foreground="#CCCCCC"
                                           FontSize="12"
                                           FontFamily="Consolas, Menlo, monospace"/>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>

                    <Border Background="#1A1A1A" CornerRadius="6" Padding="12,10">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Command="{Binding ToggleBookmarkCommand}"
                                    CommandParameter="{Binding SelectedEventDetail}"
                                    Padding="10,5"
                                    CornerRadius="4"
                                    FontSize="13">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="★" Foreground="#FFD700" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Bookmark" Foreground="#CCCCCC" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <TextBox Text="{Binding SelectedEventDetail.BookmarkComment, Mode=TwoWay}"
                                     Watermark="Add a comment..."
                                     Width="320"
                                     Background="#222222"
                                     Foreground="#FFFFFF"
                                     CornerRadius="4"
                                     Padding="8,5"/>

                            <Button Content="Save"
                                    Command="{Binding SaveBookmarkCommand}"
                                    Padding="14,5"
                                    CornerRadius="4"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

    </Grid>
</UserControl>
