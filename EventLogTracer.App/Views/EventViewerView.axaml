<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EventLogTracer.App.ViewModels"
             xmlns:core="using:EventLogTracer.Core.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="EventLogTracer.App.Views.EventViewerView"
             x:DataType="vm:EventViewerViewModel"
             x:Name="Root">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="24,24,24,12">

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Event Viewer" FontSize="28" FontWeight="Bold" Foreground="#F0F4FF"/>
            <TextBlock Text="{Binding VisibleCount, StringFormat='{}{0} events visible'}"
                       FontSize="12" Foreground="#7B8CA8" Margin="0,4,0,0"/>
        </StackPanel>

        <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox x:Name="EventViewerFilterTextBox"
                     Text="{Binding FilterText}"
                     Watermark="Filter by source, message, or event ID…"
                     Width="340" Background="#131A28" Foreground="#FFFFFF"
                     BorderBrush="#1A2744" BorderThickness="1"
                     CornerRadius="4" Padding="10,7"/>
            <StackPanel Orientation="Horizontal" Spacing="6" Margin="12,0,0,0">
                <TextBlock Text="Log:" Foreground="#7B8CA8" FontSize="12" VerticalAlignment="Center"/>
                <ComboBox ItemsSource="{Binding LogNameOptions}" SelectedItem="{Binding SelectedLogName}"
                          Width="170" Background="#131A28" Foreground="#FFFFFF" CornerRadius="4"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6" Margin="12,0,0,0">
                <TextBlock Text="Level:" Foreground="#7B8CA8" FontSize="12" VerticalAlignment="Center"/>
                <ComboBox ItemsSource="{Binding LevelOptions}" SelectedItem="{Binding SelectedLevel}"
                          Width="140" Background="#131A28" Foreground="#FFFFFF" CornerRadius="4"/>
            </StackPanel>
            <Button Content="Refresh" Command="{Binding RefreshEventsCommand}"
                    Padding="14,7" CornerRadius="4" Margin="12,0,0,0"
                    Background="#131A28" BorderBrush="#1A2744" BorderThickness="1"/>
            <Button Content="Clear" Command="{Binding ClearEventsCommand}"
                    Padding="14,7" CornerRadius="4" Margin="4,0,0,0"
                    Background="#131A28" BorderBrush="#1A2744" BorderThickness="1"/>
        </WrapPanel>

        <Grid Grid.Row="2">
            <DataGrid ItemsSource="{Binding Events}" SelectedItem="{Binding SelectedEvent}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserResizeColumns="True" CanUserSortColumns="True"
                      Background="#0C111B" GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                      BorderBrush="#1A2744" BorderThickness="1" CornerRadius="8">
                <DataGrid.Styles>
                    <Style Selector="DataGridRow">
                        <Setter Property="Background" Value="{Binding Level, Converter={StaticResource LevelBgConverter}}"/>
                        <Setter Property="Foreground" Value="{Binding Level, Converter={StaticResource LevelFgConverter}}"/>
                        <Setter Property="MinHeight" Value="30"/>
                    </Style>
                    <Style Selector="DataGridRow:pointerover /template/ Rectangle#BackgroundRectangle">
                        <Setter Property="Opacity" Value="0.6"/>
                    </Style>
                </DataGrid.Styles>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="★" Width="42">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="core:EventEntry">
                                <Button Content="{Binding IsBookmarked, Converter={StaticResource BoolToStarConverter}}"
                                        Command="{Binding #Root.DataContext.ToggleBookmarkCommand}" CommandParameter="{Binding}"
                                        Background="Transparent" Foreground="#FFD700" BorderThickness="0"
                                        Padding="4,2" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" Cursor="Hand"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Time" Width="165">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="core:EventEntry">
                                <TextBlock Text="{Binding TimeCreated, StringFormat=\{0:yyyy-MM-dd HH:mm:ss\}}" VerticalAlignment="Center" Padding="8,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Level" Width="95">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="core:EventEntry">
                                <TextBlock Text="{Binding Level}" VerticalAlignment="Center" Padding="8,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Event ID" Width="75">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="core:EventEntry">
                                <TextBlock Text="{Binding EventId}" VerticalAlignment="Center" Padding="8,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Source" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="core:EventEntry">
                                <TextBlock Text="{Binding Source}" VerticalAlignment="Center" Padding="8,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Log" Width="115">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="core:EventEntry">
                                <TextBlock Text="{Binding LogName}" VerticalAlignment="Center" Padding="8,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Machine" Width="135">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="core:EventEntry">
                                <TextBlock Text="{Binding MachineName}" VerticalAlignment="Center" Padding="8,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
            <Border Background="#660C111B" CornerRadius="6" IsVisible="{Binding IsLoading}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                    <ProgressBar IsIndeterminate="True" Width="180" Height="3" Background="Transparent"/>
                    <TextBlock Text="Loading events..." Foreground="#E8E9ED" FontSize="13" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="#0F1520" BorderBrush="#1E3A5F" BorderThickness="0,1,0,0"
                CornerRadius="0,0,8,8"
                IsVisible="{Binding SelectedEvent, Converter={x:Static ObjectConverters.IsNotNull}}">
            <ScrollViewer MaxHeight="270" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20,16" Spacing="14">
                    <WrapPanel Orientation="Horizontal">
                        <StackPanel Width="120" Margin="0,0,16,8">
                            <TextBlock Text="Event ID" FontSize="10" Foreground="#4A5670"/>
                            <TextBlock Text="{Binding SelectedEvent.EventId}" FontSize="15" FontWeight="SemiBold" Foreground="#F0F4FF"/>
                        </StackPanel>
                        <StackPanel Width="130" Margin="0,0,16,8">
                            <TextBlock Text="Level" FontSize="10" Foreground="#4A5670"/>
                            <Border CornerRadius="4" Padding="10,3" HorizontalAlignment="Left" Margin="0,2,0,0"
                                    x:CompileBindings="False"
                                    Background="{Binding SelectedEvent.Level, Converter={StaticResource LevelBgConverter}, ConverterParameter=badge}">
                                <TextBlock Text="{Binding SelectedEvent.Level}" FontSize="12" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                            </Border>
                        </StackPanel>
                        <StackPanel MinWidth="200" Margin="0,0,16,8">
                            <TextBlock Text="Source" FontSize="10" Foreground="#4A5670"/>
                            <TextBlock Text="{Binding SelectedEvent.Source}" FontSize="13" Foreground="#E8E9ED"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,8">
                            <TextBlock Text="Time Created" FontSize="10" Foreground="#4A5670"/>
                            <TextBlock Text="{Binding SelectedEvent.TimeCreated, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss.fff}'}" FontSize="13" Foreground="#E8E9ED"/>
                        </StackPanel>
                    </WrapPanel>
                    <WrapPanel Orientation="Horizontal">
                        <StackPanel Width="120" Margin="0,0,16,8">
                            <TextBlock Text="Log Name" FontSize="10" Foreground="#4A5670"/>
                            <TextBlock Text="{Binding SelectedEvent.LogName}" FontSize="13" Foreground="#E8E9ED"/>
                        </StackPanel>
                        <StackPanel Width="160" Margin="0,0,16,8">
                            <TextBlock Text="Machine" FontSize="10" Foreground="#4A5670"/>
                            <TextBlock Text="{Binding SelectedEvent.MachineName}" FontSize="13" Foreground="#E8E9ED"/>
                        </StackPanel>
                        <StackPanel Width="140" Margin="0,0,16,8">
                            <TextBlock Text="Category" FontSize="10" Foreground="#4A5670"/>
                            <TextBlock Text="{Binding SelectedEvent.Category, FallbackValue='—'}" FontSize="13" Foreground="#E8E9ED"/>
                        </StackPanel>
                        <StackPanel Width="180" Margin="0,0,16,8">
                            <TextBlock Text="User ID" FontSize="10" Foreground="#4A5670"/>
                            <TextBlock Text="{Binding SelectedEvent.UserId, FallbackValue='—'}" FontSize="13" Foreground="#E8E9ED"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,8">
                            <TextBlock Text="Keywords" FontSize="10" Foreground="#4A5670"/>
                            <TextBlock Text="{Binding SelectedEvent.Keywords, FallbackValue='—'}" FontSize="13" Foreground="#E8E9ED"/>
                        </StackPanel>
                    </WrapPanel>
                    <StackPanel Spacing="6">
                        <ItemsControl x:CompileBindings="False" ItemsSource="{Binding SelectedEventTags}">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#131A28" CornerRadius="10" Padding="8,3" Margin="0,0,6,4">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="{Binding}" Foreground="#E8E9ED" FontSize="11" VerticalAlignment="Center"/>
                                            <Button Content="✕" Command="{Binding #Root.DataContext.RemoveTagCommand}" CommandParameter="{Binding}"
                                                    Background="Transparent" BorderThickness="0" Foreground="#4A5670" FontSize="9" Padding="2,0" Cursor="Hand"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBox Text="{Binding NewTagText}" Watermark="Add tag…" Width="160" FontSize="12" Padding="7,4"
                                     Background="#131A28" Foreground="#FFFFFF" BorderBrush="#1A2744" BorderThickness="1" CornerRadius="4"/>
                            <Button Content="Add Tag" Command="{Binding AddTagCommand}"
                                    IsEnabled="{Binding NewTagText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                    Padding="10,4" FontSize="12" CornerRadius="4"
                                    Background="#131A28" BorderBrush="#1A2744" BorderThickness="1"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Message" FontSize="10" Foreground="#4A5670"/>
                        <Border Background="#080C16" CornerRadius="4" Padding="12,10" BorderBrush="#1A2744" BorderThickness="1">
                            <ScrollViewer MaxHeight="80" VerticalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding SelectedEvent.Message}" TextWrapping="Wrap"
                                           Foreground="#E8E9ED" FontSize="12" FontFamily="Consolas, Menlo, monospace"/>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                    <Border Background="#0C111B" CornerRadius="8" Padding="12,10">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Command="{Binding ToggleBookmarkCommand}" CommandParameter="{Binding SelectedEvent}"
                                    Padding="10,5" CornerRadius="4" FontSize="13">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="★" Foreground="#FFD700" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Bookmark" Foreground="#E8E9ED" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <TextBox Text="{Binding SelectedEvent.BookmarkComment, Mode=TwoWay}"
                                     Watermark="Add a comment…" Width="320"
                                     Background="#131A28" Foreground="#FFFFFF" BorderBrush="#1A2744" BorderThickness="1"
                                     CornerRadius="4" Padding="8,5"/>
                            <Button Content="Save" Command="{Binding SaveBookmarkCommand}" Padding="14,5" CornerRadius="4"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

    </Grid>
</UserControl>
