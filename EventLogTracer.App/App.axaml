<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EventLogTracer.App.App"
             xmlns:local="using:EventLogTracer.App"
             xmlns:converters="using:EventLogTracer.App.Converters"
             RequestedThemeVariant="Light">

    <Application.Resources>
        <converters:EventLevelToBackgroundConverter x:Key="LevelBgConverter"/>
        <converters:EventLevelToForegroundConverter x:Key="LevelFgConverter"/>
        <converters:BoolToStarConverter             x:Key="BoolToStarConverter"/>
        <converters:FilterDescriptionConverter      x:Key="FilterDescriptionConverter"/>
        <converters:NotificationTypeToColorConverter     x:Key="NotificationTypeToColorConverter"/>
        <converters:AnomalySeverityToColorConverter      x:Key="AnomalySeverityToColorConverter"/>
        <converters:CorrelationTypeToColorConverter      x:Key="CorrelationTypeToColorConverter"/>

        <SolidColorBrush x:Key="AccentBrush"   Color="#1160AD"/>
        <SolidColorBrush x:Key="CriticalBrush" Color="#E81123"/>
        <SolidColorBrush x:Key="ErrorBrush"    Color="#D13438"/>
        <SolidColorBrush x:Key="WarningBrush"  Color="#D97706"/>
        <SolidColorBrush x:Key="InfoBrush"     Color="#1160AD"/>
        <SolidColorBrush x:Key="VerboseBrush"  Color="#6B7280"/>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <!-- ═══════════════════════════════════════════════════════
             BUTTON — override FluentTheme via template part selectors
             ═══════════════════════════════════════════════════════ -->
        <Style Selector="Button">
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Padding"         Value="14,8"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="Medium"/>
            <Setter Property="Foreground"      Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
        <Style Selector="Button /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background"  Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background"  Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Foreground" Value="#111827"/>
        </Style>
        <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#EEF2F7"/>
        </Style>

        <!-- Primary button -->
        <Style Selector="Button.btn-primary">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.btn-primary /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background"  Value="#1160AD"/>
            <Setter Property="BorderBrush" Value="#1160AD"/>
        </Style>
        <Style Selector="Button.btn-primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background"  Value="#0D4F91"/>
            <Setter Property="BorderBrush" Value="#0D4F91"/>
        </Style>
        <Style Selector="Button.btn-primary:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#0B4580"/>
        </Style>

        <!-- Danger button -->
        <Style Selector="Button.btn-danger">
            <Setter Property="Foreground" Value="#D94A62"/>
        </Style>
        <Style Selector="Button.btn-danger /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background"  Value="#FEF2F2"/>
            <Setter Property="BorderBrush" Value="#FECACA"/>
        </Style>
        <Style Selector="Button.btn-danger:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background"  Value="#FEE2E2"/>
            <Setter Property="BorderBrush" Value="#FCA5A5"/>
        </Style>
        <Style Selector="Button.btn-danger:pointerover">
            <Setter Property="Foreground" Value="#B91C1C"/>
        </Style>

        <!-- Nav button -->
        <Style Selector="Button.nav-btn">
            <Setter Property="Padding"                    Value="16,14"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="HorizontalAlignment"        Value="Stretch"/>
            <Setter Property="CornerRadius"               Value="10"/>
            <Setter Property="Margin"                     Value="4,2"/>
            <Setter Property="FontSize"                   Value="13"/>
            <Setter Property="FontWeight"                 Value="Medium"/>
            <Setter Property="Foreground"                 Value="#374151"/>
            <Setter Property="BorderThickness"            Value="0"/>
        </Style>
        <Style Selector="Button.nav-btn /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Button.nav-btn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background"  Value="#EEF2F7"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Button.nav-btn:pointerover">
            <Setter Property="Foreground" Value="#111827"/>
        </Style>
        <Style Selector="Button.nav-btn.active">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.nav-btn.active /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background"  Value="#1160AD"/>
            <Setter Property="BorderBrush" Value="#1160AD"/>
        </Style>
        <Style Selector="Button.nav-btn.active:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background"  Value="#0D4F91"/>
            <Setter Property="BorderBrush" Value="#0D4F91"/>
        </Style>

        <!-- ═══════════════════════════════════════════════════════
             TEXTBOX
             ═══════════════════════════════════════════════════════ -->
        <Style Selector="TextBox">
            <Setter Property="Background"   Value="#FFFFFF"/>
            <Setter Property="BorderBrush"  Value="#CBD5E1"/>
            <Setter Property="Foreground"   Value="#111827"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding"      Value="10,8"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="CaretBrush"   Value="#1160AD"/>
        </Style>
        <Style Selector="TextBox /template/ Border#PART_BorderElement">
            <Setter Property="Background"  Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush"    Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#9CA3AF"/>
        </Style>

        <!-- ═══════════════════════════════════════════════════════
             COMBOBOX
             ═══════════════════════════════════════════════════════ -->
        <Style Selector="ComboBox">
            <Setter Property="Background"  Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="Foreground"  Value="#111827"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontSize"    Value="13"/>
        </Style>

        <!-- ═══════════════════════════════════════════════════════
             DATAGRID
             ═══════════════════════════════════════════════════════ -->
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background"     Value="#F8FAFC"/>
            <Setter Property="Foreground"     Value="#6B7280"/>
            <Setter Property="FontSize"       Value="11"/>
            <Setter Property="FontWeight"     Value="Medium"/>
            <Setter Property="Padding"        Value="12,10"/>
            <Setter Property="BorderBrush"    Value="#DFE4EB"/>
            <Setter Property="SeparatorBrush" Value="#DFE4EB"/>
        </Style>
        <Style Selector="DataGridRow">
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="DataGridRow:pointerover">
            <Setter Property="Background" Value="#F8FAFC"/>
        </Style>
        <Style Selector="DataGrid">
            <Setter Property="Background"              Value="#FFFFFF"/>
            <Setter Property="BorderBrush"             Value="#DFE4EB"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#F2F4F7"/>
        </Style>

        <!-- ═══════════════════════════════════════════════════════
             CALENDARDATEPICKER
             ═══════════════════════════════════════════════════════ -->
        <Style Selector="CalendarDatePicker">
            <Setter Property="Background"  Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="Foreground"  Value="#111827"/>
        </Style>

        <!-- ═══════════════════════════════════════════════════════
             TOGGLESWITCH
             ═══════════════════════════════════════════════════════ -->
        <Style Selector="ToggleSwitch">
            <Setter Property="OnContent"  Value=""/>
            <Setter Property="OffContent" Value=""/>
        </Style>

        <!-- ═══════════════════════════════════════════════════════
             SCROLLBAR
             ═══════════════════════════════════════════════════════ -->
        <Style Selector="ScrollBar /template/ Thumb">
            <Setter Property="Background" Value="#CBD5E1"/>
        </Style>

    </Application.Styles>

</Application>
