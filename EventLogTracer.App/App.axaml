<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EventLogTracer.App.App"
             xmlns:local="using:EventLogTracer.App"
             xmlns:converters="using:EventLogTracer.App.Converters"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <converters:EventLevelToBackgroundConverter x:Key="LevelBgConverter"/>
        <converters:EventLevelToForegroundConverter x:Key="LevelFgConverter"/>
        <converters:BoolToStarConverter             x:Key="BoolToStarConverter"/>
        <converters:FilterDescriptionConverter      x:Key="FilterDescriptionConverter"/>
        <converters:NotificationTypeToColorConverter     x:Key="NotificationTypeToColorConverter"/>
        <converters:AnomalySeverityToColorConverter      x:Key="AnomalySeverityToColorConverter"/>
        <converters:CorrelationTypeToColorConverter      x:Key="CorrelationTypeToColorConverter"/>

        <SolidColorBrush x:Key="AccentBrush"   Color="#3B82F6"/>
        <SolidColorBrush x:Key="CriticalBrush" Color="#E81123"/>
        <SolidColorBrush x:Key="ErrorBrush"    Color="#D13438"/>
        <SolidColorBrush x:Key="WarningBrush"  Color="#FF8C00"/>
        <SolidColorBrush x:Key="InfoBrush"     Color="#3B82F6"/>
        <SolidColorBrush x:Key="VerboseBrush"  Color="#767676"/>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <!-- ═══════════════════════════════════════════════════════
             BUTTON — override FluentTheme via template part selectors
             ═══════════════════════════════════════════════════════ -->
        <Style Selector="Button">
            <Setter Property="CornerRadius"  Value="8"/>
            <Setter Property="Padding"       Value="14,8"/>
            <Setter Property="FontSize"      Value="13"/>
            <Setter Property="FontWeight"    Value="Medium"/>
            <Setter Property="Foreground"    Value="#9BA2BE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"        Value="Hand"/>
        </Style>
        <Style Selector="Button /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background"  Value="#2F3650"/>
            <Setter Property="BorderBrush" Value="#464E6E"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background"  Value="#383F5C"/>
            <Setter Property="BorderBrush" Value="#464E6E"/>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Foreground" Value="#E8E9F0"/>
        </Style>
        <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background"  Value="#2F3650"/>
        </Style>

        <!-- Primary button -->
        <Style Selector="Button.btn-primary">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.btn-primary /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background"  Value="#3B82F6"/>
            <Setter Property="BorderBrush" Value="#3B82F6"/>
        </Style>
        <Style Selector="Button.btn-primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background"  Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
        </Style>
        <Style Selector="Button.btn-primary:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background"  Value="#1D4ED8"/>
        </Style>

        <!-- Danger button -->
        <Style Selector="Button.btn-danger">
            <Setter Property="Foreground" Value="#EF4444"/>
        </Style>
        <Style Selector="Button.btn-danger /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background"  Value="#1F1215"/>
            <Setter Property="BorderBrush" Value="#5C2B30"/>
        </Style>
        <Style Selector="Button.btn-danger:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background"  Value="#2A1518"/>
            <Setter Property="BorderBrush" Value="#7C3038"/>
        </Style>
        <Style Selector="Button.btn-danger:pointerover">
            <Setter Property="Foreground" Value="#F87171"/>
        </Style>

        <!-- Nav button — transparent bg, override later with .active -->
        <Style Selector="Button.nav-btn">
            <Setter Property="Padding"                   Value="16,14"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="HorizontalAlignment"       Value="Stretch"/>
            <Setter Property="CornerRadius"              Value="10"/>
            <Setter Property="Margin"                    Value="4,2"/>
            <Setter Property="FontSize"                  Value="13"/>
            <Setter Property="FontWeight"                Value="Medium"/>
            <Setter Property="Foreground"                Value="#9BA2BE"/>
            <Setter Property="BorderThickness"           Value="0"/>
        </Style>
        <Style Selector="Button.nav-btn /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Button.nav-btn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background"  Value="#262C44"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Button.nav-btn:pointerover">
            <Setter Property="Foreground" Value="#E8E9F0"/>
        </Style>
        <Style Selector="Button.nav-btn.active">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.nav-btn.active /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background"  Value="#3B82F6"/>
            <Setter Property="BorderBrush" Value="#3B82F6"/>
        </Style>
        <Style Selector="Button.nav-btn.active:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background"  Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
        </Style>

        <!-- ═══════════════════════════════════════════════════════
             TEXTBOX
             ═══════════════════════════════════════════════════════ -->
        <Style Selector="TextBox">
            <Setter Property="Background"    Value="#1F2539"/>
            <Setter Property="BorderBrush"   Value="#464E6E"/>
            <Setter Property="Foreground"    Value="#E8E9F0"/>
            <Setter Property="CornerRadius"  Value="8"/>
            <Setter Property="Padding"       Value="10,8"/>
            <Setter Property="FontSize"      Value="13"/>
            <Setter Property="CaretBrush"    Value="#3B82F6"/>
        </Style>
        <Style Selector="TextBox /template/ Border#PART_BorderElement">
            <Setter Property="Background"    Value="#1F2539"/>
            <Setter Property="BorderBrush"   Value="#464E6E"/>
            <Setter Property="CornerRadius"  Value="8"/>
        </Style>
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush"   Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush"   Value="#585E72"/>
        </Style>

        <!-- ═══════════════════════════════════════════════════════
             COMBOBOX
             ═══════════════════════════════════════════════════════ -->
        <Style Selector="ComboBox">
            <Setter Property="Background"  Value="#2F3650"/>
            <Setter Property="BorderBrush" Value="#464E6E"/>
            <Setter Property="Foreground"  Value="#E8E9F0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontSize"    Value="13"/>
        </Style>

        <!-- ═══════════════════════════════════════════════════════
             DATAGRID
             ═══════════════════════════════════════════════════════ -->
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background"    Value="#2F3650"/>
            <Setter Property="Foreground"    Value="#767C96"/>
            <Setter Property="FontSize"      Value="11"/>
            <Setter Property="FontWeight"    Value="Medium"/>
            <Setter Property="Padding"       Value="12,10"/>
            <Setter Property="BorderBrush"   Value="#3D4563"/>
            <Setter Property="SeparatorBrush" Value="#3D4563"/>
        </Style>
        <Style Selector="DataGridRow">
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="DataGridRow:pointerover">
            <Setter Property="Background" Value="#262C44"/>
        </Style>
        <Style Selector="DataGrid">
            <Setter Property="Background"           Value="#151A2E"/>
            <Setter Property="BorderBrush"          Value="#3D4563"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#1D2338"/>
        </Style>

        <!-- ═══════════════════════════════════════════════════════
             CALENDARDATEPICKER
             ═══════════════════════════════════════════════════════ -->
        <Style Selector="CalendarDatePicker">
            <Setter Property="Background"  Value="#1F2539"/>
            <Setter Property="BorderBrush" Value="#464E6E"/>
            <Setter Property="Foreground"  Value="#E8E9F0"/>
        </Style>

        <!-- ═══════════════════════════════════════════════════════
             SCROLLBAR
             ═══════════════════════════════════════════════════════ -->
        <Style Selector="ScrollBar /template/ Thumb">
            <Setter Property="Background" Value="#3D4563"/>
        </Style>

    </Application.Styles>

</Application>
